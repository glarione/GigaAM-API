# GigaAM Server Configuration

# Server settings
GIGAAM_HOST=0.0.0.0
GIGAAM_PORT=8000
GIGAAM_DEBUG=false

# Model settings
GIGAAM_DEFAULT_MODEL=v3_e2e_rnnt
GIGAAM_DEVICE=cuda
GIGAAM_FP16_ENCODER=true

# Hugging Face token (required for pyannote longform/diarization)
HF_TOKEN=

# Optional: segmentation model
GIGAAM_SEGMENTATION_MODEL=pyannote/segmentation-3.0
